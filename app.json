{
  "expo": {
    "name": "La Ménagère Paris",
    "slug": "lamenagere-paris",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "lamenagere",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f9f9f9"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lamenagereparis.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Pour ajouter des photos à vos demandes de devis",
        "NSPhotoLibraryUsageDescription": "Pour sélectionner des photos pour vos demandes"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f9f9f9"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.lamenagereparis.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-notifications",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-font",
      "expo-video",
      "expo-web-browser",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.lamenagereparis.app",
          "enableGooglePay": false
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://api.lamenagereparis.fr",
      "router": {},
      "eas": {
        "projectId": "789a7326-53fb-4bf6-98b9-f0c2a2529a04"
      }
    },
    "owner": "mohameddev7"
  }
}
