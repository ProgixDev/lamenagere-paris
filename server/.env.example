# PORT is provided by the hosting platform (Vercel/Railway/Render); no need to set it.
# CORS is open by default — no configuration required.

# ── Supabase ────────────────────────────────────────────
# Project: trpluywvtaecvarrzugp
SUPABASE_URL=https://trpluywvtaecvarrzugp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# JWT secret used to verify Supabase-issued access tokens (Project Settings > API > JWT Secret)
SUPABASE_JWT_SECRET=
# Storage bucket for all uploaded media
SUPABASE_STORAGE_BUCKET=media

# ── Google OAuth (mobile only) ──────────────────────────
GOOGLE_OAUTH_WEB_CLIENT_ID=
GOOGLE_OAUTH_IOS_CLIENT_ID=
GOOGLE_OAUTH_ANDROID_CLIENT_ID=

# ── Push notifications (Iteration 6) ────────────────────
# Firebase service account JSON (Android FCM) — either a path or inline JSON
FIREBASE_SERVICE_ACCOUNT_JSON=
# Expo / APNs (iOS)
EXPO_ACCESS_TOKEN=
APNS_KEY_P8=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=fr.lamenagereparis.app
