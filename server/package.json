{
  "name": "lamenagere-backend",
  "version": "0.1.0",
  "description": "Backend API for La Ménagère Paris (NestJS + Fastify + Supabase)",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "seed": "ts-node -r tsconfig-paths/register scripts/seed.ts",
    "seed:demo": "ts-node -r tsconfig-paths/register scripts/seed-demo.ts",
    "test": "jest",
    "lint": "eslint \"{src,test,scripts}/**/*.ts\""
  },
  "dependencies": {
    "@fastify/multipart": "^9.0.3",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-fastify": "^11.1.6",
    "@supabase/supabase-js": "^2.49.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "expo-server-sdk": "^3.15.0",
    "firebase-admin": "^13.10.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.8",
    "@nestjs/testing": "^11.1.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.13.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": ["ts-jest", { "tsconfig": "tsconfig.json" }]
    },
    "collectCoverageFrom": ["src/**/*.ts"],
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1"
    }
  }
}
