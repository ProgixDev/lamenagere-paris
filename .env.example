# Mobile app (Expo) — copy to .env and adjust.
# Use your machine's LAN IP (not localhost) when testing on a physical device.
EXPO_PUBLIC_API_URL=http://localhost:3333

# Supabase project — the app uses this only to run the Google OAuth (PKCE)
# flow via supabase.auth.signInWithOAuth. Find these in Supabase Dashboard >
# Project Settings > API. Google is configured entirely in the Supabase
# Dashboard (Auth > Providers > Google), not in the app.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
