# Mobile app (Expo) — copy to .env and adjust.
# Use your machine's LAN IP (not localhost) when testing on a physical device.
EXPO_PUBLIC_API_URL=http://localhost:3333

# Google OAuth client IDs (Google Cloud Console). Web client ID must also be
# registered in Supabase Auth > Providers > Google.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
