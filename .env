# Mobile app (Expo). Physical device must be on the SAME Wi-Fi as this machine.
EXPO_PUBLIC_API_URL=http://192.168.1.13:3333

# Google OAuth client IDs (from Google Cloud Console). Until set, the
# "Continuer avec Google" button is disabled. The Web client ID must also be
# added to Supabase Auth > Providers > Google.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
