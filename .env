# Mobile app (Expo).
# - iOS Simulator: use http://localhost:3333 (shares the Mac's network).
# - Android emulator: use http://10.0.2.2:3333 (alias for the host machine).
# - Physical device: use http://<your-mac-LAN-IP>:3333 on the SAME Wi-Fi.
EXPO_PUBLIC_API_URL=http://localhost:3333

